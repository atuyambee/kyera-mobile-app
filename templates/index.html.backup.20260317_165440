            console.log('Selecting crop:', crop);
            currentCrop = crop;
            
            // Update active button
            document.querySelectorAll('#cropSelector .crop-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
            
            // Load alerts for selected crop
            loadAlerts(crop);
        }

        // Load weather data
        function loadWeather() {
            fetch('/api/weather')
                .then(r => r.json())
                .then(data => {
                    document.getElementById('temperature').textContent = data.current.temp + '°C';
                    document.getElementById('weather-desc').textContent = data.current.condition;
                    document.getElementById('humidity').innerHTML = (translations[currentLang].humidity || 'Humidity') + ': ' + data.current.humidity + '%';
                    document.getElementById('weather-icon').textContent = data.current.icon;
                    
                    data.forecast.forEach((day, index) => {
                        if (index < 5) {
                            document.getElementById(`forecast-day${index+1}`).textContent = day.day;
                            document.getElementById(`forecast-temp${index+1}`).innerHTML = day.temp + '°';
                        }
                    });
                })
                .catch(error => {
                    console.error('Weather error:', error);
                });
        }

        // Load alerts for home page
        function loadAlerts(crop) {
            console.log('Loading alerts for crop:', crop);
            
            // Show loading state
            const container = document.getElementById('alerts-container');
            if (!container) return;
            
            container.innerHTML = '<div class="loading-spinner"></div><div class="loading">Loading alerts...</div>';
            
            // Fetch current alerts for this crop
            fetch('/api/alerts/' + crop)
                .then(response => {
                    console.log('Response status:', response.status);
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(alerts => {
                    console.log('Alerts received:', alerts);
                    const t = translations[currentLang];
                    let html = '';
                    
                    if (!alerts || alerts.length === 0) {
                        html = `<div class="alert" style="background:#28a745; color:white; border-left:5px solid #1e7e34; cursor:default;">
                            ✅ ${t.no_active_alerts || 'No active alerts'}
                        </div>`;
                    } else {
                        alerts.forEach((alert, index) => {
                            let riskClass = alert.risk.toLowerCase();
                            let riskTranslated = alert.risk;
                            
                            if (alert.risk === 'HIGH') riskTranslated = t.high_risk || 'HIGH RISK';
                            else if (alert.risk === 'MEDIUM') riskTranslated = t.medium_risk || 'MEDIUM RISK';
                            else if (alert.risk === 'LOW') riskTranslated = t.low_risk || 'LOW RISK';
                            
                            html += `
                                <div class="alert ${riskClass}" onclick="toggleAlertDetails(${index})">
                                    <div class="alert-header">
                                        <span class="alert-pest">${alert.pest}</span>
                                        <span class="alert-risk">${riskTranslated}</span>
                                    </div>
                                    <div class="alert-advice">${alert.advice}</div>
                                    <div class="alert-details" id="alert-details-${index}">
                                        <div class="prevention-tip">
                                            <strong>🛡️ ${t.prevention || 'Prevention'}:</strong><br>
                                            ${alert.prevention || 'Monitor crops regularly'}
                                        </div>
                                        <div class="treatment-tip">
                                            <strong>💊 ${t.treatment || 'Treatment'}:</strong><br>
                                            ${alert.treatment || 'Consult extension officer'}
                                        </div>
                                        <button class="btn" style="margin-top:10px; background:rgba(255,255,255,0.2); color:white;" 
                                            onclick="event.stopPropagation(); showFeedbackModal('${alert.pest}', ${index})">
                                            📝 ${t.feedback || 'Feedback'}
                                        </button>
                                    </div>
                                </div>
                            `;
                        });
                    }
                    
                    container.innerHTML = html;
                    
                    // Update the badge in navigation
                    const badge = document.getElementById('alert-badge');
                    if (badge) {
                        badge.textContent = alerts.length;
                        badge.style.display = alerts.length ? 'inline' : 'none';
                    }
                })
                .catch(error => {
                    console.error('Error loading alerts:', error);
                    container.innerHTML = '<div class="error-message">Failed to load alerts. Please try again.</div>';
                });
        }

        // Toggle alert details
        function toggleAlertDetails(index) {
            const alert = document.querySelectorAll('.alert')[index];
            alert.classList.toggle('expanded');
        }

        // Load weather history
        function loadWeatherHistory() {
            fetch('/api/weather/history')
                .then(r => r.json())
                .then(data => {
                    const t = translations[currentLang];
                    
                    if (!data || data.length === 0) {
                        generateDemoWeatherChart();
                        return;
                    }
                    
                    let chartHtml = '';
                    const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                    
                    data.forEach((day, index) => {
                        let date = new Date(day.date);
                        let dayName = days[date.getDay()];
                        let height = 40 + (day.temp / 30) * 80;
                        
                        chartHtml += `
                            <div class="chart-bar-wrapper" onclick="showToast('${dayName}: ${Math.round(day.temp)}°C, ${Math.round(day.humidity)}% humidity')">
                                <div class="chart-bar" style="height: ${height}px;">
                                    <span class="chart-value">${Math.round(day.temp)}°</span>
                                </div>
                                <div class="chart-label">${dayName}</div>
                                <div class="chart-humidity">${Math.round(day.humidity)}%</div>
                            </div>
                        `;
                    });
                    
                    document.getElementById('weather-chart').innerHTML = chartHtml;
                    
                    let avgTemp = Math.round(data.reduce((sum, d) => sum + d.temp, 0) / data.length);
                    let avgHumidity = Math.round(data.reduce((sum, d) => sum + d.humidity, 0) / data.length);
                    
                    let firstTemp = data[0]?.temp || 0;
                    let lastTemp = data[data.length-1]?.temp || 0;
                    let trend = lastTemp > firstTemp ? t.weather_trend_rising : t.weather_trend_falling;
                    document.getElementById('weather-trend').textContent = trend;
                    
                    document.getElementById('weather-summary').innerHTML = `
                        <div class="summary-item">
                            <span class="summary-icon">🌡️</span>
                            <span class="summary-text">${t.avg_temp}:</span>
                            <span class="summary-value">${avgTemp}°C</span>
                        </div>
                        <div class="summary-item">
                            <span class="summary-icon">💧</span>
                            <span class="summary-text">${t.avg_humidity}:</span>
                            <span class="summary-value">${avgHumidity}%</span>
                        </div>
                    `;
                })
                .catch(error => {
                    console.error('Weather history error:', error);
                    generateDemoWeatherChart();
                });
        }

        // Generate demo weather chart
        function generateDemoWeatherChart() {
            const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            const today = new Date().getDay();
            let demoHtml = '';
            
            const temps = [26, 25, 24, 25, 26, 27, 26];
            const humidities = [65, 62, 60, 63, 68, 70, 67];
            
            for (let i = 0; i < 7; i++) {
                let dayIndex = (today + i) % 7;
                let dayName = days[dayIndex];
                let temp = temps[i];
                let humidity = humidities[i];
                let height = 40 + (temp / 30) * 80;
                
                demoHtml += `
                    <div class="chart-bar-wrapper">
                        <div class="chart-bar" style="height: ${height}px;">
                            <span class="chart-value">${temp}°</span>
                        </div>
                        <div class="chart-label">${dayName}</div>
                        <div class="chart-humidity">${humidity}%</div>
                    </div>
                `;
            }
            
            document.getElementById('weather-chart').innerHTML = demoHtml;
            document.getElementById('weather-trend').textContent = '📈 Rising';
            document.getElementById('weather-summary').innerHTML = `
                <div class="summary-item">
                    <span class="summary-icon">🌡️</span>
                    <span class="summary-text">Avg Temperature:</span>
                    <span class="summary-value">25°C</span>
                </div>
                <div class="summary-item">
                    <span class="summary-icon">💧</span>
                    <span class="summary-text">Avg Humidity:</span>
                    <span class="summary-value">66%</span>
                </div>
            `;
        }

        // Load alert history
        function loadHistory(crop) {
            document.querySelectorAll('#historyCropSelector .crop-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            
            if (crop !== 'all') {
                event.target.classList.add('active');
            } else {
                document.getElementById('history-all').classList.add('active');
            }
            
            document.getElementById('history-container').innerHTML = '<div class="loading-spinner"></div><div class="loading">Loading history...</div>';
            
            let url = crop === 'all' ? '/api/alerts/all' : '/api/history/' + crop;
            
            fetch(url)
                .then(r => r.json())
                .then(alerts => {
                    const t = translations[currentLang];
                    let html = '';
                    
                    if (alerts.length === 0) {
                        html = '<div style="padding:30px; text-align:center; color:#999;">' + t.no_active_alerts + '</div>';
                    } else {
                        alerts.forEach(alert => {
                            const date = new Date(alert.date).toLocaleString();
                            const farmerInfo = alert.farmer_name ? `👤 ${alert.farmer_name}` : '';
                            html += `
                                <div class="history-item" onclick="viewAlertDetails('${alert.pest}')">
                                    <div>
                                        <div class="history-pest">${alert.pest}</div>
                                        <div class="history-date">${date}</div>
                                        ${farmerInfo ? `<div style="font-size:10px; color:#666; margin-top:2px;">${farmerInfo}</div>` : ''}
                                    </div>
                                    <div>
                                        <span class="history-risk ${alert.risk.toLowerCase()}">${alert.risk}</span>
                                    </div>
                                </div>
                            `;
                        });
                    }
                    
                    document.getElementById('history-container').innerHTML = html;
                })
                .catch(error => {
                    console.error('History error:', error);
                    document.getElementById('history-container').innerHTML = '<div class="error-message">Failed to load history</div>';
                });
        }

        // View alert details
        function viewAlertDetails(pest) {
            showToast(`📋 Details for ${pest}`);
        }

        // Load stats
        function loadStats() {
            fetch('/api/stats')
                .then(r => r.json())
                .then(data => {
                    document.getElementById('farmer-count').textContent = data.total_farmers || 0;
                    document.getElementById('alert-count').textContent = data.total_alerts || 0;
                    document.getElementById('today-count').textContent = data.today_alerts || 0;
                })
                .catch(error => {
                    console.error('Stats error:', error);
                });
        }

        // Load profile
        function loadProfile() {
            const phone = localStorage.getItem('farmer_phone');
            if (phone) {
                fetch('/api/farmer/' + phone)
                    .then(r => r.json())
                    .then(farmer => {
                        if (!farmer.error) {
                            document.getElementById('reg-name').value = farmer.name || '';
                            document.getElementById('reg-phone').value = farmer.phone || '';
                            document.getElementById('reg-village').value = farmer.village || '';
                            document.getElementById('reg-crop').value = farmer.main_crop || 'maize';
                            document.getElementById('reg-size').value = farmer.farm_size || '';
                            document.getElementById('reg-other').value = farmer.other_crops || '';
                            document.getElementById('reg-language').value = farmer.language || 'en';
                            
                            currentFarmer = farmer;
                            
                            fetch('/api/farmer/' + farmer.id + '/stats')
                                .then(r => r.json())
                                .then(stats => {
                                    document.getElementById('profile-alerts').textContent = stats.total_alerts || 0;
                                    document.getElementById('profile-read').textContent = stats.read_count || 0;
                                    document.getElementById('profile-feedback').textContent = stats.feedback_count || 0;
                                });
                        }
                    })
                    .catch(error => {
                        console.error('Profile error:', error);
                    });
            }
        }

        // Register farmer
        function registerFarmer() {
            const data = {
                name: document.getElementById('reg-name').value,
                phone: document.getElementById('reg-phone').value,
                village: document.getElementById('reg-village').value,
                main_crop: document.getElementById('reg-crop').value,
                farm_size: document.getElementById('reg-size').value,
                other_crops: document.getElementById('reg-other').value,
                language: document.getElementById('reg-language').value
            };
            
            if (!data.name || !data.phone) {
                alert(translations[currentLang].full_name + ' and ' + translations[currentLang].phone_number + ' required');
                return;
            }
            
            fetch('/api/register', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            })
            .then(r => r.json())
            .then(result => {
                if (result.success) {
                    alert(result.message);
                    localStorage.setItem('farmer_phone', data.phone);
                    loadProfile();
                    loadStats();
                    showToast('Registration successful!');
                } else {
                    alert('Error: ' + result.message);
                }
            })
            .catch(error => {
                alert('Registration failed');
            });
        }

        // Load farmer alerts
        function loadFarmerAlerts() {
            if (!currentFarmer) {
                alert('Please register first');
                return;
            }
            showToast('Loading your alerts...');
            showPage('alerts');
            setTimeout(() => {
                loadHistory('all');
            }, 200);
        }

        // Mark all as read
        function markAllAsRead() {
            if (!currentFarmer) return;
            showToast('Marking all as read...');
            setTimeout(() => {
                showToast('All alerts marked as read');
            }, 1000);
        }

        // Show feedback history
        function showFeedbackHistory() {
            showToast('Feedback history feature coming soon');
        }

        // Logout
        function logout() {
            localStorage.removeItem('farmer_phone');
            currentFarmer = null;
            document.getElementById('reg-name').value = '';
            document.getElementById('reg-phone').value = '';
            document.getElementById('reg-village').value = '';
            document.getElementById('reg-crop').value = 'maize';
            document.getElementById('reg-size').value = '';
            document.getElementById('reg-other').value = '';
            document.getElementById('reg-language').value = 'en';
            document.getElementById('profile-alerts').textContent = '0';
            document.getElementById('profile-read').textContent = '0';
            document.getElementById('profile-feedback').textContent = '0';
            showToast('Logged out successfully');
        }

        // Show feedback modal
        function showFeedbackModal(pestName, alertIndex) {
            currentAlert = {
                pest: pestName,
                index: alertIndex
            };
            document.getElementById('feedback-modal').classList.add('active');
        }

        // Set rating
        function setRating(rating) {
            currentRating = rating;
            document.querySelectorAll('.rating-star').forEach((star, i) => {
                star.classList.toggle('selected', i < rating);
            });
        }

        // Submit feedback
        function submitFeedback() {
            const feedback = {
                farmer_id: currentFarmer?.id,
                alert_id: currentAlert?.index,
                rating: currentRating,
                comment: document.getElementById('feedback-comment').value,
                pest_observed: document.getElementById('feedback-observed').value === 'true'
            };
            
            fetch('/api/feedback', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(feedback)
            })
            .then(r => r.json())
            .then(() => {
                alert(translations[currentLang].thank_you);
                closeModal();
                loadProfile();
            })
            .catch(() => {
                alert('Thank you for your feedback!');
                closeModal();
            });
        }

        // Close modal
        function closeModal() {
            document.getElementById('feedback-modal').classList.remove('active');
            currentRating = 0;
            document.querySelectorAll('.rating-star').forEach(s => s.classList.remove('selected'));
            document.getElementById('feedback-comment').value = '';
            document.getElementById('feedback-observed').value = 'true';
        }

        // Service Worker for PWA
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/static/service-worker.js')
                    .then(reg => console.log('ServiceWorker registered'))
                    .catch(err => console.log('ServiceWorker error:', err));
            });
        }

        // Initialize app
        function init() {
            loadWeather();
            loadAlerts('maize');
            loadWeatherHistory();
            loadStats();
            loadProfile();
            updateUIText();
        }

        document.addEventListener('DOMContentLoaded', init);

        // Auto-refresh every 30 minutes
        setInterval(() => {
            if (document.getElementById('home-page').classList.contains('active-page')) {
                loadWeather();
                loadAlerts(currentCrop);
                loadWeatherHistory();
                loadStats();
            }
        }, 1800000);
    </script>
</body>
</html>
