            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            event.currentTarget.classList.add('active');
            
            if (page === 'home') {
                loadWeather();
                loadAlerts(currentCrop);
                loadWeatherHistory();
            } else if (page === 'alerts') {
                loadHistory('all');
            } else if (page === 'profile') {
                loadProfile();
            }
            
            updateUIText();
        }

