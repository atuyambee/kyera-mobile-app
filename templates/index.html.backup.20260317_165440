            setTimeout(() => {
                loadHistory('all');
            }, 200);
        }

        // View today's alerts
        function viewTodayAlerts() {
            const count = document.getElementById('today-count').textContent;
            showToast(`📅 Loading today's alerts...`);
            
            fetch('/api/alerts/today')
                .then(r => r.json())
                .then(alerts => {
                    if (alerts.length === 0) {
                        alert('📅 No alerts today');
                        return;
                    }
                    
                    let message = `📅 Today's Alerts (${count}):\n\n`;
                    alerts.forEach((alert, index) => {
                        message += `${index + 1}. ${alert.pest} - ${alert.risk}\n`;
                        message += `   ${alert.advice.substring(0, 60)}...\n`;
                        if (alert.farmer_name) {
                            message += `   👤 ${alert.farmer_name}\n`;
                        }
                        message += '\n';
                    });
                    alert(message);
                })
                .catch(() => {
                    alert(`📅 Today's Alerts: ${count}`);
                });
