                            html += `
                                <div class="farmer-item" onclick="viewFarmerDetails('${farmer.phone}')">
                                    <div>
                                        <div class="farmer-name">${farmer.name}</div>
                                        <div style="font-size:11px; color:#666;">${farmer.village || 'No village'}</div>
                                    </div>
                                    <div class="farmer-crop">${farmer.main_crop}</div>
                                </div>
