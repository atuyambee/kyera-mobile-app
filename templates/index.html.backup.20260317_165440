            setTimeout(() => {
                toast.style.display = 'none';
            }, duration);
        }

        // View farmers list
        function viewFarmers() {
            const count = document.getElementById('farmer-count').textContent;
            showToast(`📋 Loading farmers list...`);
            
            fetch('/api/farmers/list')
                .then(r => r.json())
                .then(farmers => {
                    const modal = document.getElementById('farmers-modal');
                    const listDiv = document.getElementById('farmers-list');
                    
                    if (farmers.length === 0) {
                        listDiv.innerHTML = '<div style="text-align:center; padding:20px;">No farmers registered</div>';
                    } else {
                        let html = '<div style="margin-bottom:10px; font-weight:bold;">Total: ' + farmers.length + ' farmers</div>';
